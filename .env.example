# ===========================================================================
# Optimist Computers Voice Agent - Environment Variables Configuration
# Copy this file to '.env' and fill in your values.
# ===========================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Your Deepgram API Key from https://console.deepgram.com
DEEPGRAM_API_KEY=e4bab2a4281d66d69daa75522ac3581096709ce1

# ---------------------------------------------------------------------------
# Optional Server Settings
# ---------------------------------------------------------------------------
# The host/IP the server will bind to (default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# The port the server will run on (default: 8080)
SERVER_PORT=8080

# The public domain/URL where your server is exposed (e.g., via ngrok).
# Required for live Twilio phone calls, so Twilio knows where to route audio.
# Example: https://xxxx.ngrok-free.app
SERVER_EXTERNAL_URL=

# ---------------------------------------------------------------------------
# Optional Voice Agent Configuration
# ---------------------------------------------------------------------------
# Deepgram Text-to-Speech (TTS) Voice Model.
# Options include: aura-2-asteria-en, aura-2-thalia-en, etc.
VOICE_MODEL=aura-2-asteria-en

# LLM Reasoning Model configured in Deepgram's Think settings.
# Options include: gpt-4o-mini, gpt-4o, claude-3-5-sonnet, gemini-1.5-flash
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Optional Twilio Telephony Settings
# ---------------------------------------------------------------------------
# Credentials used to terminate calls or request signature validation.
TWILIO_ACCOUNT_SID=AC1c3335b05009a6e118a661b104bc1710
TWILIO_AUTH_TOKEN=46c4334cb786683e5621ff991305474d
TWILIO_PHONE_NUMBER=+1 712 214 7734

# Optional webhook secret token path parameter to secure your endpoints.
# If set, your webhook URLs become /incoming-call/<WEBHOOK_SECRET>
WEBHOOK_SECRET=
